<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
             xmlns:views="clr-namespace:SantaSecilia.Views"
             x:Class="SantaSecilia.Views.BoletaSemanalPage"
             BackgroundColor="#FAF4C6">

    <ScrollView>
        <VerticalStackLayout Spacing="20">
            
            <VerticalStackLayout >
                <!-- Header -->
                <views:HeaderView Grid.Row="0"
								  x:Name="MyHeader"/>

                <VerticalStackLayout Padding="25" Spacing="18">

                    <!-- Título -->
                    <Label Text="Boleta Semanal"
						   FontSize="28"
						   FontAttributes="Bold"
						   HorizontalOptions="Center"
						   TextColor="Black"/>

                    <!-- Selectores -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                        <!-- Trabajador -->
                        <VerticalStackLayout>
                            <Label Text="Nombre del Trabajador"
								   TextColor="Black"
								   FontSize="13"/>

                            <Border Stroke="#888"
									StrokeShape="RoundRectangle 10"
									Background="White">
                                <Picker HeightRequest="40"
                                        TextColor="Black"
                                        ItemsSource="{Binding Trabajadores}"
                                        SelectedItem="{Binding TrabajadorSeleccionado}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Semana -->
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Semana"
								   TextColor="Black"
								   FontSize="13"/>

                            <Border Stroke="#888"
									StrokeShape="RoundRectangle 10"
									Background="White">
                                <Picker HeightRequest="40"
                                        TextColor="Black"
                                        ItemsSource="{Binding Semanas}"
                                        SelectedItem="{Binding SemanaSeleccionada}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

					
                    <!-- TABLA -->
                    <Border Stroke="#7A8FA6"
							StrokeThickness="2"
							Background="White"
							StrokeShape="RoundRectangle 15"
							HeightRequest="330">
                        <Grid RowDefinitions="Auto,*">

                            <!-- Header -->
                            <Grid Background="#80BFFF"
								  Padding="8"
								  ColumnDefinitions="1.2*,2*,1*,1*,1.2*">
                                <Label Text="Fecha" TextColor="Black" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="Actividad" TextColor="Black" FontAttributes="Bold"/>
                                <Label Grid.Column="2" Text="Horas" TextColor="Black" FontAttributes="Bold"/>
                                <Label Grid.Column="3" Text="Tarifa" TextColor="Black" FontAttributes="Bold"/>
                                <Label Grid.Column="4" Text="Monto" TextColor="Black" FontAttributes="Bold"/>
                            </Grid>

                            <!-- Área Scroll -->
                            <ScrollView Grid.Row="1">
                                <VerticalStackLayout Padding="5" Spacing="6">
                                    <CollectionView ItemsSource="{Binding Filas}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="1.2*,2*,1*,1*,1.2*">
                                                    <Label Text="{Binding Fecha, StringFormat='{0:dd/MM}'}" TextColor="Black"/>
                                                    <Label Grid.Column="1" Text="{Binding Actividad}" TextColor="Black"/>
                                                    <Label Grid.Column="2" Text="{Binding Horas}" TextColor="Black"/>
                                                    <Label Grid.Column="3" Text="{Binding Tarifa} " TextColor="Black"/>
                                                    <Label Grid.Column="4" Text="{Binding Monto} " TextColor="Black"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <Grid ColumnDefinitions="1.2*,2*,1*,1*,1.2*">
                                        <Label Text=""/>
                                        <Label Grid.Column="1" Text="" TextColor="Black"/>
                                        <Label Grid.Column="2" Text="" TextColor="Black"/>
                                        <Label Grid.Column="3" Text="" TextColor="Black"/>
                                        <Label Grid.Column="4" Text="" TextColor="Black"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </ScrollView>
                        </Grid>
                    </Border>

					
					
                    <!-- Totales -->
                    <Border Stroke="#7A8FA6"
							Background="White"
							StrokeShape="RoundRectangle 15"
							Padding="15">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding TotalDevengado, StringFormat='Total Devengado: B/. {0:F2}'}"
                                   TextColor="Black"/>
                            <Label Text="{Binding Descuentos, StringFormat='Descuentos: B/. {0:F2}'}"
                                    TextColor="Black"/>
                            <Label Text="{Binding TotalPagar, StringFormat='Total a pagar: B/. {0:F2}'}"
                                   TextColor="Black"/>
                        </VerticalStackLayout>
                    </Border>

                  <HorizontalStackLayout HorizontalOptions="Center"
										 Spacing="25"
										 Margin="0,15,0,0">


                        <!-- Imprimir -->
                        <Border BackgroundColor="#B2FBA5"
								StrokeShape="RoundRectangle 12"
								Padding="0">

                            <Button Text="Imprimir"
									BackgroundColor="Transparent"
									TextColor="Black"
									Padding="25,8"
                                    Clicked="Imprimir_Clicked"/>
                        </Border>
                  </HorizontalStackLayout>
              </VerticalStackLayout>
         </VerticalStackLayout>
      </VerticalStackLayout>
  </ScrollView>
</ContentPage>