<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="#FDFBF7"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
    x:Class="SantaSecilia.Views.EditarActividadPage">

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="30" MaximumWidthRequest="1200" HorizontalOptions="Center">

            <VerticalStackLayout Spacing="8">
                <Label Text="Editar Actividad" TextColor="#0EA5E9" FontSize="36" FontAttributes="Bold"/>
                <Label Text="Modifique los detalles de la actividad seleccionada." TextColor="#64748B" FontSize="16"/>
            </VerticalStackLayout>

            <Border BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="50">

                <Grid ColumnDefinitions="2*, 1*" ColumnSpacing="50">

                    <VerticalStackLayout Grid.Column="0" Spacing="30">

                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="Información General" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Nombre de la Actividad" FontSize="14" FontAttributes="Bold" TextColor="#64748B"/>

                            <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="15,0" HeightRequest="55">
                                <Entry Text="{Binding Actividad}"
                                       TextColor="#1A202C"
                                       FontSize="16"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="1.5*, 1*" ColumnSpacing="15">

                            <VerticalStackLayout Grid.Column="0" Spacing="10">
                                <Label Text="Tarifa por Hora (PAB)" FontSize="14" FontAttributes="Bold" TextColor="#64748B"/>

                                <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="15,0" HeightRequest="55">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Label Grid.Column="0" Text="B/." VerticalOptions="Center" TextColor="#94A3B8" FontAttributes="Bold" Margin="0,0,8,0" FontSize="16"/>

                                        <Entry Grid.Column="1" 
                                               Text="{Binding Tarifa, StringFormat='{0}'}"
                                               Keyboard="Numeric"
                                               TextColor="#1A202C"
                                               FontSize="16"
                                               BackgroundColor="Transparent"/>

                                        <Label Grid.Column="2" Text="PAB" VerticalOptions="Center" TextColor="#94A3B8" FontSize="14" FontAttributes="Bold"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="10">
                                <Label Text="Estado" FontSize="14" FontAttributes="Bold" TextColor="#64748B"/>

                                <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="15,0" HeightRequest="55">
                                    <Picker ItemsSource="{Binding EstadoOpciones}"
                                            SelectedItem="{Binding EstadoSeleccionado}"
                                            TextColor="#1A202C"
                                            FontSize="16"
                                            BackgroundColor="Transparent"
                                            VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="Transparent" Margin="0,20"/>

                        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">

                            <Button Text="Cancelar"
                                    BackgroundColor="White"
                                    TextColor="#475569"
                                    BorderColor="#CBD5E0"
                                    BorderWidth="1"
                                    CornerRadius="8"
                                    HeightRequest="55"
                                    Padding="30,0"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    Command="{Binding CancelarCommand}"/>

                            <Button Text="Guardar Cambios"
                                    BackgroundColor="#A8E6CF"
                                    TextColor="#1B4332"
                                    CornerRadius="8"
                                    HeightRequest="55"
                                    Padding="30,0"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    Command="{Binding GuardarCommand}"/>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                    <Grid Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center">
                        <Image Source="logo.png"
                               Aspect="AspectFit"
                               MaximumHeightRequest="800"
                               Opacity="0.8"/>
                    </Grid>

                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>