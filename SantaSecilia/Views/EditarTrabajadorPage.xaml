<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
             x:Class="SantaSecilia.Views.EditarTrabajadorPage"
             BackgroundColor="#FDFBF7">

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="30" MaximumWidthRequest="1200" HorizontalOptions="Center">

            <VerticalStackLayout Spacing="8">
                <Label Text="Editar Trabajador" TextColor="#0EA5E9" FontSize="36" FontAttributes="Bold"/>
                <Label Text="Modifique los campos necesarios para actualizar el registro." TextColor="#64748B" FontSize="16"/>
            </VerticalStackLayout>

            <Border BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="50">

                <Grid ColumnDefinitions="*, 350" ColumnSpacing="50">

                    <VerticalStackLayout Grid.Column="0" Spacing="30">

                        <Label Text="Información del Perfil" FontSize="20" FontAttributes="Bold" TextColor="#1E293B"/>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Nombre Completo" FontSize="14" FontAttributes="Bold" TextColor="#64748B"/>
                            <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="0" HeightRequest="55">
                                <Entry Text="{Binding Nombre}"
                                       TextColor="#1A202C"
                                       FontSize="16"
                                       Margin="15,0"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Fill"/>
                            </Border>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <VerticalStackLayout Grid.Column="0" Spacing="10">
                                <Label Text="Número de Cédula" FontSize="14" FontAttributes="Bold" TextColor="#64748B"/>
                                <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="0" HeightRequest="55">
                                    <Entry Text="{Binding Cedula}"
                                           TextColor="#1A202C"
                                           FontSize="16"
                                           Margin="15,0"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Fill"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="10">
                                <Label Text="Estado" FontSize="14" FontAttributes="Bold" TextColor="#64748B"/>
                                <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="0" HeightRequest="55">
                                    <Picker ItemsSource="{Binding Estados}"
                                            SelectedItem="{Binding EstadoSeleccionado}"
                                            TextColor="#1A202C"
                                            FontSize="16"
                                            Margin="10,0"
                                            BackgroundColor="Transparent"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Fill"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="Transparent" Margin="0,20"/>

                        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                            <Button Text="Cancelar"
                                    BackgroundColor="White"
                                    TextColor="#475569"
                                    BorderColor="#CBD5E0"
                                    BorderWidth="1"
                                    CornerRadius="8"
                                    HeightRequest="55"
                                    Padding="30,0"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    Clicked="OnCancelarClicked"/>

                            <Button Text="Actualizar Datos"
                                    BackgroundColor="#A8E6CF"
                                    TextColor="#1B4332"
                                    CornerRadius="8"
                                    HeightRequest="55"
                                    Padding="30,0"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    Command="{Binding GuardarCommand}"/>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                    <Grid Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center">
                        <Image Source="logo.png"
                               Aspect="AspectFit"
                               MaximumHeightRequest="800"
                               Opacity="0.8"/>
                    </Grid>

                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>