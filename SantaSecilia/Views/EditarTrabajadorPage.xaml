<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
    x:Class="SantaSecilia.Views.EditarTrabajadorPage"
    BackgroundColor="#FAF4C6">

    <Grid>
        <!-- Card principal -->
        <Border Stroke="Black"
				StrokeThickness="1"
				BackgroundColor="White"
				StrokeShape="RoundRectangle 28"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				WidthRequest="540">
            
            <VerticalStackLayout Spacing="0">

                <!-- HEADER -->
                <Border BackgroundColor="#80BFFF"
						StrokeShape="RoundRectangle 10,5,0,0"
						Padding="16">
					
                    <Label Text="Editar Trabajador"
						   FontSize="20"
						   TextColor="Black"
						   FontAttributes="Bold"
						   HorizontalOptions="Center"/>
                </Border>

                <!-- CONTENIDO -->
                <Grid Padding="20"
                      ColumnDefinitions="*,220">
                    
                    <!-- FORM -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Nombre Completo" FontSize="12" TextColor="Black"/>
                        <Border Stroke="#CCCCCC"
								StrokeShape="RoundRectangle 10">
                            <Entry Text="{Binding Nombre}"
								   TextColor="Black"
								   BackgroundColor="Transparent"/>
                        </Border>

                        <Label Text="Cédula" FontSize="12" TextColor="Black"/>
                        <Border Stroke="#CCCCCC" 
								StrokeShape="RoundRectangle 10">
                            <Entry
                                Text="{Binding Cedula}"
                                TextColor="Black"
                                BackgroundColor="Transparent"/>
                        </Border>

                        <Label Text="Estado" FontSize="12" TextColor="Black"/>
                        <Border Stroke="#CCCCCC" StrokeShape="RoundRectangle 10">
                            <Picker ItemsSource="{Binding Estados}"
                                    SelectedItem="{Binding EstadoSeleccionado}"
									TextColor="Black"
									BackgroundColor="Transparent"/>
                        </Border>

                        <!-- BOTONES -->
                        <HorizontalStackLayout Spacing="20" Margin="10,10,0,0">
                            <Button Text="Guardar"
									BackgroundColor="#B2FBA5"
									TextColor="Black"
									CornerRadius="15"
									WidthRequest="120"
									Command="{Binding GuardarCommand}"/>

                            <Button Text="Cancelar"
									BackgroundColor="#F57E76"
									TextColor="Black"
									CornerRadius="15"
									WidthRequest="120"
									Clicked="OnCancelarClicked"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- IMAGEN -->
                    <Image Grid.Column="1"
						   Source="logo.png"
						   Aspect="AspectFit"
						   HorizontalOptions="Center"
						   VerticalOptions="Center"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>