<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SantaSecilia"
             x:Class="SantaSecilia.Views.LoginPage"
             BackgroundColor="#FDFBF7">
    <ScrollView>
    <Grid>

        <Border BackgroundColor="White"
                Stroke="#A8E6CF" 
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="50"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="450">

            <Border.Shadow>
                <Shadow Brush="#0F172A" Offset="0,10" Radius="30" Opacity="0.05" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">

                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">

                        <BoxView WidthRequest="80" HeightRequest="4" Color="#A8E6CF"  CornerRadius="2" HorizontalOptions="Center" Margin="0,0,0,10"/>

                        <Image Source="logo.png" 
                           Aspect="AspectFit"
                           HeightRequest="150"  WidthRequest="150"   HorizontalOptions="Center"
                           Margin="0,0,0,0"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Bananera Santa Cecilia"
                               TextColor="#1E293B"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>

                        <Label Text="Sistema de Control Agrícola"
                               TextColor="#64748B"
                               FontSize="14"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <Border BackgroundColor="#FEF2F2" 
                        Stroke="#FECACA" 
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 8" 
                        Padding="15,10"
                        IsVisible="{Binding HasError}">

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#DC2626"
                           FontSize="13"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#0EA5E9"
                                   HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="10">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Usuario" 
                               TextColor="#475569" 
                               FontSize="13" 
                               FontAttributes="Bold"/>

                        <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="15,5" HeightRequest="55">
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">

                                <Image Source="user_icon.png" 
                                       HeightRequest="20" 
                                       WidthRequest="20" 
                                       VerticalOptions="Center" 
                                        />

                                <Entry Placeholder="Ingrese su usuario o correo"
                                       Text="{Binding Username}"
                                       TextColor="#1E293B"
                                       PlaceholderColor="#94A3B8"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       WidthRequest="250"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Contraseña" 
                               TextColor="#475569" 
                               FontSize="13" 
                               FontAttributes="Bold"/>

                        <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 10" BackgroundColor="White" Padding="15,5" HeightRequest="55">
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">

                                <Image Source="lock_icon.png" 
                                       HeightRequest="20" 
                                       WidthRequest="20" 
                                       VerticalOptions="Center" 
                                       Opacity="0.6" />

                                <Entry Placeholder="••••••••"
                                       Text="{Binding Password}"
                                       IsPassword="True"
                                       TextColor="#1E293B"
                                       PlaceholderColor="#94A3B8"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       WidthRequest="250"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Iniciar Sesión"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#A8E6CF" 
                            TextColor="#1B4332" 
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="10"
                            HeightRequest="50"
                            HorizontalOptions="Fill"
                            Margin="0,25,0,0"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,10,0,0"/>

                    <Label Text="© 2026 Finca Bananera Santa Cecilia.&#x0a;Todos los derechos reservados.&#x0a;XYZ Solutions" 
                       TextColor="#94A3B8" 
                       FontSize="11" 
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
    </ScrollView>
</ContentPage>