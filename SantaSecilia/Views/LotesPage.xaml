<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
    xmlns:views="clr-namespace:SantaSecilia.Views"
    x:Class="SantaSecilia.Views.LotesPage"
    BackgroundColor="#FAF4C6">

	<!-- GRID PRINCIPAL -->
	<Grid RowDefinitions="Auto,*">

		<!-- HEADER -->
		<views:HeaderView
            Grid.Row="0"
            x:Name="MyHeader"/>

		<!-- CONTENIDO -->
		<Grid Grid.Row="1"
              Padding="20"
              RowDefinitions="Auto,Auto,Auto,*"
              RowSpacing="15">

			<!-- TÍTULO -->
			<Label Grid.Row="0"
                   Text="Gestionar Lotes"
                   TextColor="Black"
                   FontSize="28"
                   FontAttributes="Bold"/>

			<!-- BOTÓN REGISTRAR -->
			<Button Grid.Row="2"
                    Text="+ Registrar lote"
                    Command="{Binding RegistrarCommand}"
                    HorizontalOptions="Start"
                    BackgroundColor="#B2FBA5"
                    TextColor="Black"
                    CornerRadius="12"
                    BorderColor="#949C94"
                    BorderWidth="1"
                    Padding="12,6"/>

			<!-- LISTA CON SCROLL AUTOMÁTICO -->
			<CollectionView Grid.Row="3"
                            ItemsSource="{Binding Lotes}"
                            HorizontalOptions="Center"
                            MaximumWidthRequest="550"
                            VerticalOptions="FillAndExpand"
                            VerticalScrollBarVisibility="Always">

				<!-- HEADER DE TABLA -->
				<CollectionView.Header>
					<Border BackgroundColor="#80BFFF"
                            StrokeShape="RoundRectangle 12"
                            Padding="10">
						<Grid ColumnDefinitions="1*,2*,Auto,Auto">
							<Label Text="Código"
                                   TextColor="Black"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
								   Margin="0,0,65,0"/>
							
							<Label Grid.Column="1"
                                   Text="Estado"
                                   TextColor="Black"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
								   Margin="0,0,276,0"/>
						</Grid>
					</Border>
				</CollectionView.Header>

				<!-- ITEMS -->
				<CollectionView.ItemTemplate>
					<DataTemplate>
						<Border Margin="0,6"
                                Padding="12"
                                BackgroundColor="White"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">

							<Grid ColumnDefinitions="1*,2*,Auto,Auto">

								<!-- Código -->
								<Label Text="{Binding Code}"
                                       TextColor="Black"
                                       HorizontalOptions="Center"
                                       Margin="0,15,10,0"/>

								<!-- Estado -->
								<Label Grid.Column="1"
                                       Text="{Binding EstadoTexto}"
                                       TextColor="Black"
                                       HorizontalOptions="Center"
                                       Margin="0,15,25,0"/>

								<!-- BOTÓN EDITAR -->
								<Button Grid.Column="2"
                                        Text="Editar"
                                        BackgroundColor="#80BFFF"
                                        TextColor="Black"
                                        CornerRadius="10"
                                        FontSize="12"
                                        Margin="20,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarCommand}"
                                        CommandParameter="{Binding .}"
                                        HorizontalOptions="End"/>

								<!-- BOTÓN ELIMINAR -->
								<Button Grid.Column="3"
                                        Text="Eliminar"
                                        BackgroundColor="#F57E76"
                                        TextColor="Black"
                                        CornerRadius="10"
                                        FontSize="12"
                                        Margin="10,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarCommand}"
                                        CommandParameter="{Binding .}"
                                        HorizontalOptions="End"/>

							</Grid>
						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>

			</CollectionView>

		</Grid>

	</Grid>

</ContentPage>
