<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    BackgroundColor="#FDFBF7"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
    x:Class="SantaSecilia.Views.RegistrarLotesPage">

    <Grid>
        <Border BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="40,30"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="500"
                    Margin="20,40">

            <VerticalStackLayout Spacing="2">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">

                    <Image Source="logo.png"
                               Aspect="AspectFit"
                               HeightRequest="180"
                               WidthRequest="180"
                               HorizontalOptions="Center"
                               Margin="0,0,0,0"/>

                    <Label Text="Registrar Lote"
                               TextColor="#1E293B"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>

                    <Label Text="Ingrese el identificador y el estado operativo del nuevo sector de cultivo."
                               TextColor="#64748B"
                               FontSize="14"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="Transparent" Margin="0,5"/>

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Código del Lote" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   TextColor="#64748B"/>

                        <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="15,0" HeightRequest="55">
                            <Entry Placeholder="Ej: L-104"
                                       Text="{Binding Codigo}"
                                       TextColor="#1A202C"
                                       FontSize="16"
                                       BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Estado" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   TextColor="#64748B"/>

                        <Border Stroke="#CBD5E0" StrokeShape="RoundRectangle 8" BackgroundColor="White" Padding="15,0" HeightRequest="55">
                            <Picker ItemsSource="{Binding Estados}"
                                        SelectedItem="{Binding EstadoSeleccionado}"
                                        TextColor="#1A202C"
                                        FontSize="16"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="Transparent" Margin="0,10"/>

                <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">

                    <Button Text="Cancelar"
                                BackgroundColor="White"
                                TextColor="#475569"
                                BorderColor="#CBD5E0"
                                BorderWidth="1"
                                CornerRadius="8"
                                HeightRequest="55"
                                Padding="30,0"
                                FontSize="16"
                                FontAttributes="Bold"
                                Command="{Binding CancelarCommand}"/>

                    <Button Text="Registrar Lote"
                                BackgroundColor="#A8E6CF"
                                TextColor="#1B4332"
                                CornerRadius="8"
                                HeightRequest="55"
                                Padding="30,0"
                                FontSize="16"
                                FontAttributes="Bold"
                                Command="{Binding RegistrarCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>