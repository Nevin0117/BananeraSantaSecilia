<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SantaSecilia.ViewModels"
             xmlns:views="clr-namespace:SantaSecilia.Views"
             xmlns:conv="clr-namespace:SantaSecilia.Converters"
             x:Class="SantaSecilia.Views.TrabajadoresListPage"
             BackgroundColor="#FDFBF7">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:FirstLetterConverter x:Key="FirstLetterConv" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <views:HeaderView Grid.Row="0" x:Name="MyHeader"/>

        <Grid Grid.Row="1" Padding="40,30">
            <Border MaximumWidthRequest="1100"
                    HorizontalOptions="Center"
                    VerticalOptions="Fill"
                    BackgroundColor="White" 
                    StrokeShape="RoundRectangle 12" 
                    Stroke="#A8E6CF" 
                    Padding="0">

                <Grid RowDefinitions="Auto, Auto, *, Auto">

                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="30,12" BackgroundColor="White">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Gestionar Trabajadores" FontSize="28" FontAttributes="Bold" TextColor="#1A202C"/>
                            <Label Text="Listado oficial de personal y números de cédula." FontSize="14" TextColor="#718096"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Border StrokeShape="RoundRectangle 8" Stroke="#CBD5E0" BackgroundColor="#F9FAFB" Padding="15,0" WidthRequest="250" HeightRequest="45">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Image Grid.Column="0" Source="search_icon.png" HeightRequest="18" WidthRequest="18" VerticalOptions="Center" Opacity="0.5"/>
                                    <Entry Grid.Column="1" Placeholder="Buscar..." Text="{Binding Busqueda}" FontSize="13" VerticalOptions="Center" TextColor="#1E293B" BackgroundColor="Transparent"/>
                                    <ImageButton Grid.Column="2" Source="x_icon.png" Command="{Binding LimpiarBusquedaCommand}" IsVisible="{Binding IsSearching}" HeightRequest="12" WidthRequest="12" VerticalOptions="Center" BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                            <Button Text="+ Registrar Trabajador" Command="{Binding RegistrarCommand}" BackgroundColor="#A8E6CF" TextColor="#1B4332" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" Padding="20,0"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="1*, 4*, 2.5*, 2*, 1.5*" Padding="30,10" BackgroundColor="#E3F2FD" MinimumWidthRequest="1100">
                        <Label Grid.Column="0" Text="CÓDIGO" FontSize="14" FontAttributes="Bold" TextColor="#2D3748"/>
                        <Label Grid.Column="1" Text="NOMBRE COMPLETO" FontSize="14" FontAttributes="Bold" TextColor="#2D3748"/>
                        <Label Grid.Column="2" Text="CÉDULA" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="3" Text="ESTADO" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="4" Text="ACCIONES" FontSize="14" FontAttributes="Bold" TextColor="#2D3748" HorizontalTextAlignment="Center"/>
                    </Grid>

                    <CollectionView Grid.Row="2" 
                                    ItemsSource="{Binding Trabajadores}"
                                    VerticalOptions="Fill">
                        <CollectionView.EmptyView>
                            <ContentView VerticalOptions="Fill" HorizontalOptions="Fill">
                                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15" Padding="0,50">
                                    <Image Source="search_icon.png" HeightRequest="80" WidthRequest="80" Opacity="0.2"/>
                                    <Label Text="No se encontraron trabajadores" TextColor="#94A3B8" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                    <Label Text="Intenta con otro término de búsqueda" TextColor="#CBD5E1" FontSize="14" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </ContentView>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrabajadorItem">
                                <Border StrokeThickness="0" BackgroundColor="Transparent">

                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal" />
                                                <VisualState x:Name="PointerOver">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor" Value="#F1F5F9" />
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>

                                    <VerticalStackLayout>
                                        <Grid ColumnDefinitions="1*, 4*, 2.5*, 2*, 1.5*" Padding="30,18">

                                            <Label Grid.Column="0" Text="{Binding Codigo}" VerticalOptions="Center" TextColor="#718096" FontSize="13"/>

                                            <HorizontalStackLayout Grid.Column="1" Spacing="15" VerticalOptions="Center">
                                                <Border WidthRequest="42" HeightRequest="42" BackgroundColor="#E0F2FE" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                                                    <Label Text="{Binding Nombre, Converter={StaticResource FirstLetterConv}}" TextColor="#0284C7" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Border>
                                                <Label Text="{Binding Nombre}" VerticalOptions="Center" FontAttributes="Bold" TextColor="#2D3748" FontSize="15"/>
                                            </HorizontalStackLayout>

                                            <Label Grid.Column="2" Text="{Binding Cedula}" VerticalOptions="Center" HorizontalOptions="Center" TextColor="#4A5568" FontSize="15"/>

                                            <Border Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Padding="12,4" StrokeShape="RoundRectangle 15" BackgroundColor="#E8F5E9" Stroke="Transparent">
                                                <Label Text="{Binding Estado}" TextColor="#2E7D32" FontSize="11" FontAttributes="Bold">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Estado}" Value="Inactivo">
                                                            <Setter Property="TextColor" Value="#64748B" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Estado}" Value="Inactivo">
                                                        <Setter Property="BackgroundColor" Value="#E2E8F0" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                            </Border>

                                            <HorizontalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="10">
                                                <Button ImageSource="edit_icon.png" 
                                                        BackgroundColor="Transparent" 
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditarCommand}" 
                                                        CommandParameter="{Binding .}"/>

                                                <Button ImageSource="delete_icon.png" 
                                                        BackgroundColor="Transparent" 
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminarCommand}" 
                                                        CommandParameter="{Binding .}">
                                                </Button>
                                            </HorizontalStackLayout>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#EDF2F7" Margin="30,0" HorizontalOptions="Fill"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid Grid.Row="3" Padding="30,15" BackgroundColor="White">
                        <Label Text="Listado de Personal · Finca Santa Secilia" FontSize="12" TextColor="#94A3B8" HorizontalOptions="Center"/>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>